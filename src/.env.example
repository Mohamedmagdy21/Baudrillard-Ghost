APP_NAME="Baudrillard's GHOST"
APP_VERSION="0.1"

FILE_ALLOWED_TYPES=["text/plain","application/pdf"]
FILE_MAX_SIZE=10
FILE_DEFAULT_CHUNK_SIZE=512000


######################################### LLM Config ########################
GENERATION_BACKEND="GLM"
EMBEDDING_BACKEND="COHERE"

ZAI_API_KEY=""
COHERE_API_KEY=""

ZAI_URL=""

GENERATION_MODEL="glm-5.2"
EMBEDDING_MODEL="embed-v4.0"
EMBEDDING_MODEL_DIMENSIONS=1024
DEFAULT_INPUT_MAX_TOKENS=1024
GENERATION_DEFAULT_MAX_TOKENS=200
GENERATION_DEFAULT_TEMPERATURE=0.1


########################################## Vector DB Config####################
VECTOR_DB_BACKEND="QDRANT"
VECTOR_DB_PATH="qdrant_db"
VECTOR_DB_DISTANCE="cosine"



################################### Templates Configs ####################

DEFAULT_LANGAUGE="en"


############################ Agents key###############
REWRITER_BASE_URL="http://localhost:11434/v1/"
REWRITER_API_KEY="ollama"
REWRITER_MODEL="qwen3:4b"
RETRY_THRESHOLD=0.6
MAX_RETRIES=3